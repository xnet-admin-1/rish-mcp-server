{
  "name": "rish-mcp-server",
  "version": "1.2.0",
  "description": "MCP server for Android system access via Shizuku",
  "author": "Josh Fordyce",
  "organization": "XNet Inc.",
  "license": "GPL-3.0",
  "main": "src/server_direct.py",
  "entrypoint": "python3 -m src.server_direct",
  "type": "mcp-server",
  "runtime": "python",
  "requirements": {
    "python": ">=3.10"
  },
  "tools": [
    {
      "name": "shell",
      "description": "Execute Android shell commands via Shizuku"
    },
    {
      "name": "terminal",
      "description": "Interactive terminal session"
    }
  ],
  "install": "pip3 install -r requirements.txt",
  "start": "python3 src/server_direct.py"
}